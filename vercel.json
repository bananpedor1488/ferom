{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "node scripts/vercel-build.mjs",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://138.124.18.118/api/:path*"
    },
    {
      "source": "/ws",
      "destination": "http://138.124.18.118/ws"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://138.124.18.118/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
